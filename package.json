{
  "name": "gumtree-keyword-watcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "run:once": "tsx src/run-once.ts",
    "guard:routines": "bash scripts/routine-parent-guard.sh",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:once": "node dist/run-once.js",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "verify": "bash scripts/verify.sh"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "dotenv": "^16.6.1",
    "twilio": "^5.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
